<%- include ('../partials/header.ejs') %>

<body>
  <div class="container" style="width: 50%">
    <div class="card" style="margin-top: 3rem; text-align: center">
      <div class="card-header">
        <h1>Cargos</h1>
        <div class="card-body">
          <table class="table table-striped">
            <thead>
              <tr>
                <th scope="col">Id</th>
                <th scope="col">Título</th>
                <th scope="col">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% ocuppations.forEach(ocuppation => { %>
              <tr>
                <td><%= ocuppation.id %></td>
                <td><%= ocuppation.ocuppation %></td>
                <td>
                  <a href="/ocuppations/edit/<%= ocuppation.id %>"
                    ><button class="btn btn-primary">Atualizar</button></a
                  >
                  <a href="/ocuppations/remove/<%= ocuppation.id %>">
                    <button class="btn btn-danger">Remover</button></a
                  >
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <a href="/ocuppations/register">
            <button class="btn" style="float: right; background-color: #1bbf4f">
              Novo cargo
            </button>
          </a>
        </div>
      </div>
    </div>
  </div>
</body>

<%- include ('../partials/footer.ejs') %>
